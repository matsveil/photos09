<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox prefHeight="800.0" prefWidth="1200.0" spacing="0.0" styleClass="root-container" stylesheets="@home.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.matsvei.photosapp.admin.AdminController">
    
    <!-- Header Section -->
    <VBox styleClass="header-section">
        <padding>
            <Insets bottom="20.0" left="30.0" right="30.0" top="20.0" />
        </padding>
        
        <HBox alignment="CENTER_LEFT" spacing="15.0">
            <Label styleClass="welcome-text" text="Admin Panel" HBox.hgrow="ALWAYS" />
            <Button fx:id="logoutButton" onAction="#onLogout" styleClass="secondary-button" text="Log out" />
        </HBox>
    </VBox>
    
    <!-- Main Content -->
    <VBox spacing="20.0" VBox.vgrow="ALWAYS">
        <padding>
            <Insets bottom="30.0" left="30.0" right="30.0" top="25.0" />
        </padding>
        
        <!-- Users Header -->
        <HBox alignment="CENTER_LEFT" spacing="10.0">
            <Label styleClass="section-title" text="Users" />
            <Region HBox.hgrow="ALWAYS" />
        </HBox>
        
        <!-- Users List -->
        <ScrollPane fitToWidth="true" styleClass="users-scroll" VBox.vgrow="ALWAYS">
            <VBox.margin>
                <Insets top="10.0" />
            </VBox.margin>
            <ListView fx:id="userListView" styleClass="user-list" />
        </ScrollPane>
    </VBox>
    
    <!-- Action Bar -->
    <VBox styleClass="action-bar">
        <padding>
            <Insets bottom="25.0" left="30.0" right="30.0" top="25.0" />
        </padding>
        
        <HBox alignment="CENTER" spacing="12.0">
            <Button fx:id="createUserButton" onAction="#onCreateUser" styleClass="primary-button" text="+ New User" />
            <Button fx:id="deleteUserButton" onAction="#onDeleteUser" styleClass="delete-button" text="Delete User" />
        </HBox>
    </VBox>
</VBox>
