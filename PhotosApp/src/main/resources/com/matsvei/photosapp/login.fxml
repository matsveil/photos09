<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" prefHeight="800.0" prefWidth="1200.0" spacing="0.0" styleClass="root-container" stylesheets="@home.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.matsvei.photosapp.login.LoginController">
    
    <!-- Login Card -->
    <VBox alignment="CENTER" maxWidth="450.0" spacing="30.0" styleClass="login-card">
        <padding>
            <Insets bottom="50.0" left="50.0" right="50.0" top="50.0" />
        </padding>
        
        <!-- Title -->
        <Label styleClass="login-title" text="Photos" />
        <Label styleClass="login-subtitle" text="Sign in to your account" />
        
        <!-- Username Field -->
        <VBox spacing="8.0">
            <Label styleClass="field-label" text="Username" />
            <TextField fx:id="usernameField" promptText="Enter username" styleClass="input-field" />
        </VBox>
        
        <!-- Password Field -->
        <VBox spacing="8.0">
            <Label styleClass="field-label" text="Password (optional)" />
            <PasswordField fx:id="passwordField" promptText="Enter password" styleClass="input-field" />
        </VBox>
        
        <!-- Login Button -->
        <Button fx:id="loginButton" maxWidth="Infinity" onAction="#onLogin" styleClass="primary-button" text="Log in" />
        
        <!-- Divider -->
        <HBox alignment="CENTER" spacing="10.0">
            <Region HBox.hgrow="ALWAYS" styleClass="divider-line" />
            <Label styleClass="divider-text" text="or" />
            <Region HBox.hgrow="ALWAYS" styleClass="divider-line" />
        </HBox>
        
        <!-- Sign Up Button -->
        <Button fx:id="signupButton" maxWidth="Infinity" onAction="#onSignup" styleClass="secondary-button-large" text="Create new account" />
    </VBox>
</VBox>
